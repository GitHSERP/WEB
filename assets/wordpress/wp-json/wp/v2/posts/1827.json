{"id":1827,"date":"2025-06-12T14:35:32","date_gmt":"2025-06-12T06:35:32","guid":{"rendered":"https:\/\/www.hserp.tw\/wordpress\/?p=1827"},"modified":"2025-06-12T14:39:30","modified_gmt":"2025-06-12T06:39:30","slug":"workshop","status":"publish","type":"post","link":"https:\/\/www.hserp.tw\/wordpress\/2025\/06\/12\/workshop\/","title":{"rendered":"\u6703\u8a08\u8edf\u9ad4\u61c9\u7528\u8aaa\u660e\u53ca\u4f7f\u7528\u5fc3\u5f97\u5206\u4eab\u82b1\u7d6e"},"content":{"rendered":"\n<p>\u96a8\u8457\u79d1\u6280\u5feb\u901f\u767c\u5c55\u8207\u71df\u904b\u74b0\u5883\u7684\u8b8a\u9077\uff0c\u6578\u4f4d\u8f49\u578b\u5df2\u6210\u70ba\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240\u7684\u91cd\u8981\u8ab2\u984c\u3002\u70ba\u5354\u52a9\u6703\u8a08\u5e2b\u638c\u63e1\u79d1\u6280\u3001\u843d\u5be6\u8f49\u578b\uff0c\u5947\u52dd\u8cc7\u8a0a\u53d7\u9080\u53c3\u8207\u4e2d\u83ef\u6703\u5be9\u8ca1\u7a05\u5c08\u696d\u5354\u6703\u8209\u8fa6\u7684\u8aaa\u660e\u6703\uff0c\u4e3b\u984c&lt;&lt;<strong>\u6703\u8a08\u8edf\u9ad4\u61c9\u7528\u8aaa\u660e\u53ca\u4f7f\u7528\u5fc3\u5f97\u5206\u4eab<\/strong>&gt;&gt;\u8207\u591a\u4f4d\u8cc7\u6df1\u6703\u8a08\u5e2b\uff0c\u91dd\u5c0d\u6578\u4f4d\u8f49\u578b\u904e\u7a0b\u4e2d\u5be6\u969b\u4f7f\u7528\u7684\u5de5\u5177\u8207\u7d93\u9a57\u9032\u884c\u6df1\u5165\u4ea4\u6d41\u53ca\u5206\u4eab\u3002<\/p>\n\n\n\n<p>\u6703\u4e2d\uff0c\u6211\u5011\u5c55\u793a\u4e86\u7a05\u52d9\u6703\u8a08\u53ca\u5be9\u8a08\u7c3d\u8b49\u7cfb\u7d71\u7d50\u5408\u6578\u4f4d\u5316\u5de5\u5177\uff0c\u5305\u62ec\u6191\u8b49e\u5316\u3001xAI\u5927\u8056\u667a\u80fd\u8fa8\u8b58\u3001RoboTax\u81ea\u52d5\u5316\u5de5\u5177\u7b49\u529f\u80fd\uff0c\u900f\u904e\u5be6\u969b\u6848\u4f8b\u8207\u7cfb\u7d71\u64cd\u4f5c\uff0c\u6211\u5011\u8207\u6703\u8a08\u5e2b\u4e00\u540c\u63a2\u8a0e\u5982\u4f55\u5728\u5de5\u4f5c\u6d41\u7a0b\u4e2d\u5c0e\u5165\u65b0\u5de5\u5177\uff0c\u6709\u6548\u89e3\u6c7a\u4eba\u529b\u5403\u7dca\u8207\u4f5c\u696d\u6548\u7387\u63d0\u5347\u7684\u96d9\u91cd\u6311\u6230\u3002<\/p>\n\n\n\n<p>\u5728\u5206\u4eab\u7684\u904e\u7a0b\u4e2d\uff0c\u4e5f\u7279\u5225\u63d0\u53ca\u300c\u6d41\u7a0b\u6a19\u6e96\u5316\u300d\u5728\u6578\u4f4d\u8f49\u578b\u4e2d\u7684\u95dc\u9375\u3002\u552f\u6709\u5148\u5efa\u7acb\u6e05\u6670\u4e00\u81f4\u7684\u4f5c\u696d\u6d41\u7a0b\uff0c\u6578\u4f4d\u5de5\u5177\u624d\u80fd\u771f\u6b63\u767c\u63ee\u6548\u80fd\uff0c\u9032\u4e00\u6b65\u5be6\u73fe\u81ea\u52d5\u5316\u3001\u667a\u6167\u5316\u7684\u4f5c\u696d\u6a21\u5f0f\uff0c\u6e1b\u5c11\u4eba\u70ba\u932f\u8aa4\u8207\u91cd\u5de5\uff0c\u63d0\u5347\u6574\u9ad4\u670d\u52d9\u54c1\u8cea\u3002<\/p>\n\n\n\n<figure class=\"wp-block-image size-large\"><img loading=\"lazy\" width=\"1024\" height=\"783\" src=\"https:\/\/www.hserp.tw\/wordpress\/wp-content\/uploads\/2025\/06\/730064-1024x783.jpg\" alt=\"\" class=\"wp-image-1829\" srcset=\"https:\/\/www.hserp.tw\/wordpress\/wp-content\/uploads\/2025\/06\/730064-1024x783.jpg 1024w, https:\/\/www.hserp.tw\/wordpress\/wp-content\/uploads\/2025\/06\/730064-300x229.jpg 300w, https:\/\/www.hserp.tw\/wordpress\/wp-content\/uploads\/2025\/06\/730064-768x587.jpg 768w, https:\/\/www.hserp.tw\/wordpress\/wp-content\/uploads\/2025\/06\/730064-78x60.jpg 78w, https:\/\/www.hserp.tw\/wordpress\/wp-content\/uploads\/2025\/06\/730064.jpg 1231w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" \/><\/figure>\n\n\n\n<p>\u5728\u4ea4\u6d41\u73fe\u5834\uff0c\u6703\u8a08\u5e2b\u5011\u7a4d\u6975\u63d0\u554f\u8207\u56de\u994b\uff0c\u4e26\u91dd\u5c0d\u5404\u9805\u529f\u80fd\u5206\u4eab\u5be6\u52d9\u4f7f\u7528\u9700\u6c42\uff0c\u5c55\u73fe\u51fa\u5c0d\u6578\u4f4d\u5de5\u5177\u7684\u9ad8\u5ea6\u95dc\u6ce8\u3002<\/p>\n\n\n\n<p>\u6211\u5011\u76f8\u4fe1\uff0c\u5de5\u5177\u662f\u8f14\u52a9\uff0c\u6d41\u7a0b\u624d\u662f\u8f49\u578b\u7684\u771f\u6b63\u6838\u5fc3\u3002\u82e5\u80fd\u5c07\u5de5\u4f5c\u6a21\u5f0f\u6a19\u6e96\u5316\u3001\u4f5c\u696d\u6d41\u7a0b\u6a21\u7d44\u5316\uff0c\u518d\u5c0e\u5165\u5408\u9069\u7684\u5de5\u5177\u8207\u7cfb\u7d71\uff0c\u8b93\u8f49\u578b\u4e0d\u518d\u53ea\u662f\u6280\u8853\u5347\u7d1a\uff0c\u800c\u662f\u5be6\u8cea\u63d0\u5347\u6548\u7387\u8207\u54c1\u8cea\u7684\u7b56\u7565\u6539\u8b8a\u3002<\/p>\n\n\n\n<p>\u82e5\u60a8\u6b63\u898f\u5283\u4e8b\u52d9\u6240\u6578\u4f4d\u8f49\u578b\uff0c\u6b61\u8fce\u586b\u5beb<a href=\"https:\/\/docs.google.com\/forms\/d\/e\/1FAIpQLSc8m-Dp-fhXfCROGOGlb_dk-LAo_OvT5RAOriL89txUr5NEtg\/viewform\" target=\"_blank\" rel=\"noreferrer noopener\">\u7dda\u4e0a\u8a62\u50f9\u55ae<\/a>\u6216\u4f86\u96fb\u5404\u5340\u696d\u52d9\u8aee\u8a62\uff0c\u5947\u52dd\u8cc7\u8a0a\u5c07\u63d0\u4f9b\u5c08\u696d\u5efa\u8b70\u8207\u5be6\u52d9\u5354\u52a9\uff0c\u6210\u70ba\u60a8\u8f49\u578b\u8def\u4e0a\u7684\u5805\u5f37\u5925\u4f34\u3002<\/p>\n\n\n\n<p>\u53f0\u5317\u5340\u696d\u52d9\u300002-22577401#319<\/p>\n\n\n\n<p>\u53f0\u4e2d\u5340\u696d\u52d9\u300004-23202807#30<\/p>\n\n\n\n<p>\u53f0\u5357\u5340\u696d\u52d9\u300006-2006219#20<\/p>\n\n\n\n<p>\u9ad8\u96c4\u5340\u696d\u52d9\u300007-3805919<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u96a8\u8457\u79d1\u6280\u5feb\u901f\u767c\u5c55\u8207\u71df\u904b\u74b0\u5883\u7684\u8b8a\u9077\uff0c\u6578\u4f4d\u8f49\u578b\u5df2\u6210\u70ba\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240\u7684\u91cd\u8981\u8ab2\u984c\u3002\u70ba\u5354\u52a9\u6703\u8a08\u5e2b\u638c\u63e1\u79d1\u6280\u3001\u843d\u5be6\u8f49\u578b\uff0c\u5947\u52dd\u8cc7\u8a0a\u53d7\u9080\u53c3\u8207 &hellip; <\/p>\n","protected":false},"author":1,"featured_media":1828,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"standard","meta":[],"categories":[6],"tags":[30,5],"_links":{"self":[{"href":"https:\/\/www.hserp.tw\/wordpress\/wp-json\/wp\/v2\/posts\/1827"}],"collection":[{"href":"https:\/\/www.hserp.tw\/wordpress\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/www.hserp.tw\/wordpress\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/www.hserp.tw\/wordpress\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/www.hserp.tw\/wordpress\/w