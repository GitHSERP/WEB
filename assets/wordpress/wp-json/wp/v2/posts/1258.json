{"id":1258,"date":"2022-02-09T09:40:14","date_gmt":"2022-02-09T01:40:14","guid":{"rendered":"http:\/\/www.hserp.tw\/wordpress\/?p=1258"},"modified":"2022-06-16T09:23:48","modified_gmt":"2022-06-16T01:23:48","slug":"efile","status":"publish","type":"post","link":"https:\/\/www.hserp.tw\/wordpress\/2022\/02\/09\/efile\/","title":{"rendered":"\u5168\u65b0\u63a8\u51fa\u3010\u4f01\u696de\u6587\u4ef6\u3011"},"content":{"rendered":"\n<p>\u653f\u5e9c\u63a8\u884c\u96fb\u5b50\u767c\u7968\u653f\u7b56\u6578\u9918\u5e74\uff0c\u76ee\u524d\u6b63\u671d\u5411\u5168\u9762\u7121\u7d19\u5316\u76ee\u6a19\u63a8\u52d5\u3002\u800c\u5947\u52dd\u8cc7\u8a0a\u540c\u6642\u4e5f\u63a8\u51fa\u6191\u8b49e\u5316\u9081\u5165\u7b2c\u4e94\u5e74\uff0c\u73fe\u5df2\u6709\u7d04\u56db\u6210\u6703\u8a08\u5e2b\u3001\u7a05\u52d9\u8a18\u5e33\u58eb\u4f7f\u7528\u6191\u8b49\uff45\u5316\u3002\u5728\u670d\u52d9\u5c0e\u5165\u7684\u904e\u7a0b\u4e2d\uff0c\u6211\u5011\u6536\u5230\u8a31\u591a\u5ba2\u6236\u7684\u53cd\u994b\u53ca\u80af\u5b9a\uff0c\u8a8d\u70ba\u9019\u5957\u8edf\u9ad4\u52a0\u901f\u4e86\u4e8b\u52d9\u6240\u6578\u4f4d\u5316\u767c\u5c55\uff0c\u85c9\u4ee5\u63d0\u5347\u4f5c\u696d\u6d41\u7a0b\u6548\u7387\uff0c\u9019\u4f7f\u6211\u5011\u66f4\u52a0\u78ba\u4fe1\u6578\u4f4d\u8f49\u578b\u80fd\u5275\u9020\u66f4\u597d\u7684\u4f01\u696d\u5354\u540c\u5408\u4f5c\u9ad4\u9a57\u3002<\/p>\n\n\n\n<p>\u56e0\u6b64\uff0c\u5947\u52dd\u8cc7\u8a0a\u7684\u6211\u7b97\u7b97\u9032\u92b7\u5b58\u7cfb\u7d71\u5c07\u91cd\u78c5\u63a8\u51fa\u3010\u4f01\u696de\u6587\u4ef6\u3011\u529f\u80fd\uff0c\u8b93\u6211\u7b97\u7b97\u9019\u5957\u7c21\u6613\u64cd\u4f5c\u3001\u529f\u80fd\u9f4a\u5168\u7684\u7cfb\u7d71\u66f4\u52a0\u5f37\u5927\u3002\u4f01\u696de\u6587\u4ef6\u53ef\u5c07\u6a94\u6848\u5feb\u901f\u6574\u5408\u65bc\u7cfb\u7d71\u4e2d\uff0c\u8b93\u4f01\u696d\u5167\u90e8\u66f4\u6709\u7cfb\u7d71\u6027\u7684\u904b\u7528\u53ca\u6b78\u6a94\u6587\u4ef6\uff0c\u540c\u6642\u9054\u5230\u5167\u90e8\u55ae\u64da\u7684\u76f8\u95dc\u8cc7\u8a0a\u5168\u9762e\u5316\u3002<\/p>\n\n\n<figure class=\"wp-block-gallery columns-1 is-cropped\">\n<figure><img class=\"wp-image-1217\" src=\"http:\/\/www.hserp.tw\/wordpress\/wp-content\/uploads\/3001\/2022\/02\/%E6%88%91%E7%AE%97%E7%AE%97%E4%BC%81%E6%A5%ADe%E6%96%87%E4%BB%B6-1-1024x724.png\" alt=\"\" data-id=\"1217\" data-full-url=\"http:\/\/hserp.tw:3001\/wordpress\/wp-content\/uploads\/2022\/02\/\u6211\u7b97\u7b97\u4f01\u696de\u6587\u4ef6-1.png\" data-link=\"http:\/\/hserp.tw:3001\/wordpress\/2022\/02\/09\/%e5%85%a8%e6%96%b0%e6%8e%a8%e5%87%ba%e3%80%90%e4%bc%81%e6%a5%ad-e-%e6%96%87%e4%bb%b6%e3%80%91\/%e6%88%91%e7%ae%97%e7%ae%97%e4%bc%81%e6%a5%ade%e6%96%87%e4%bb%b6-1\/\" \/><\/figure>\n<\/figure>\n<p>\u3010\u4f01\u696d e \u6587\u4ef6\u3011\u4ecb\u7d39<\/p>\n<p><!-- \/wp:paragraph --><\/p>\n<p><!-- wp:list {\"ordered\":true} --><\/p>\n<p>\u4e00\u3001\u5404\u7a2e\u6a94\u6848\u4e0d\u9650\u526f\u6a94\u683c\u5f0f\u7686\u53ef\u593e\u6a94\uff0c\u4f01\u696d\u6587\u66f8\u5e38\u7528\u7684word\u3001Excel\u3001PDF\u3001jpg\u3001\u751a\u81f3\u5f71\u7247\u6a94\uff0c\u7686\u53ef\u5c07\u55ae\u64da\u7522\u751f\u95dc\u806f\uff0c\u8b93\u4f01\u696d\u6587\u4ef6\u5b8c\u6574\u6b78\u6a94\u3002<\/p>\n<p style=\"text-align: left;\">\u4e8c\u300118\u7a2e\u55ae\u64da\u7686\u6709e\u6587\u4ef6\u529f\u80fd\u8b93\u60a8\u898f\u5283\u904b\u7528<br \/>\u3000 \u92b7\u552e\u6a21\u7d44\uff1a\u5831\u50f9\u55ae\u3001\u8a02\u55ae\u3001\u51fa\u8ca8\u55ae\u3001\u92b7\u9000\u6298\u55ae<br \/>\u3000 \u9032\u8ca8\u6a21\u7d44\uff1a\u8acb\u8cfc\u55ae\u3001\u63a1\u8cfc\u55ae\u3001\u9032\u8ca8\u55ae\u3001\u9032\u9000\u6298\u55ae<br \/>\u3000 \u5eab\u5b58\u6a21\u7d44\uff1a\u7d44\u5408\u3001\u62c6\u89e3\u3001\u76e4\u9ede\u3001\u8abf\u6574\u3001\u8abf\u64a5<br \/>\u00a0 \u00a0 \u00a0\u8ca1\u6703\u6a21\u7d44\uff1a\u50b3\u7968\u00a0 \u00a0\u00a0\u00a0 \u00a0<br \/>\u3000 \u57fa\u672c\u8cc7\u6599\uff1a\u5ba2\u6236\u3001\u5ee0\u5546\u3001\u5546\u54c1\u3001\u54e1\u5de5\u3001\u9280\u884c<\/p>\n<p>\u4e09\u3001\u593e\u6a94\u65b9\u5f0f\u591a\u5143\uff0c\u60a8\u53ef\u9078\u64c7\u6a94\u6848\u5feb\u901f\u62d6\u62c9\u3001\u4f7f\u7528\u6211\u7b97\u7b97\u5167\u5efa\u6a94\u6848\u6aa2\u8996\u5de5\u5177\u53ef\u9810\u89bd\u5716\u6a94\u9078\u64c7\u6a94\u6848\uff0c\u6216\u5982\u60a8\u60f3\u5c07\u624b\u4e0a\u7d19\u672c\u6587\u4ef6\u5feb\u901f\uff45\u5316\u4e5f\u53ef\u4f7f\u7528\u5167\u5efa\u6383\u63cf\u529f\u80fd\u642d\u914d\u5404\u5f0f\u6383\u63cf\u6a5f\u5b8c\u6210\u4e00\u9375\u593e\u6a94\u3002<\/p>\n<p><!-- \/wp:list --><\/p>\n<p><!-- wp:paragraph {\"align\":\"left\"} --><\/p>\n<p class=\"has-text-align-left\">\u3010\u4f01\u696de\u6587\u4ef6\u3011\u7d50\u5408\u6211\u7b97\u7b97\u57fa\u790e\u529f\u80fd\u53ef\u4ee5\u505a\u5230<\/p>\n<p><!-- \/wp:paragraph --><\/p>\n<p>\u3000 \u25cf \u6a94\u6848\u540c\u6b65\u4e3b\u6a5f\u9054\u5230\u4f01\u696d\u8cc7\u8a0a\u5171\u4eab<br \/>\u3000 \u25cf \u6587\u4ef6\u7570\u52d5\u53ca\u522a\u9664\u7d00\u9304\u67e5\u627e<br \/>\u3000 \u25cf \u55ae\u64da\u593e\u5e36\u4e4b\u5716\u6a94\u3001PDF\u6a94\u5feb\u901f\u6efe\u52d5\u9810\u89bd<br \/>\u3000 \u25cf \u5be9\u6838\u5b8c\u6210\u5c07\u593e\u6a94\u9396\u5b9a\u4e0d\u518d\u88ab\u7570\u52d5<br \/>\u3000 \u25cf \u900f\u904eweb\u7db2\u8def\u5354\u5b9a\u5b58\u653e\u4e3b\u6a5f\uff0c\u7121\u9700\u5c0d\u61c9\u7db2\u8def\u78c1\u789f\u6a5f\u9054\u5230\u6b0a\u9650\u7ba1\u5236\u7de8\u8f2f\u53ca\u522a\u9664\u64cd\u4f5c<\/p>\n<p><!-- \/wp:list --><\/p>\n<p><!-- wp:paragraph --><\/p>\n<p>\u5982\u4f55\u6709\u6548\u7387\u7684\u7ba1\u7406\u6563\u4f48\u5728\u4f01\u696d\u5167\u90e8\u5404\u5f0f\u6587\u4ef6\u6a94\u6848\uff0c\u4e00\u76f4\u662f\u516c\u53f8\u8cc7\u8a0a\u7ba1\u7406\u7684\u91cd\u8981\u8ab2\u984c\u3002\u904e\u5f80\u4e2d\u5c0f\u4f01\u696d\u7919\u65bc\u4eba\u529b\u3001\u9810\u7b97\u7b49\u554f\u984c\uff0c\u591a\u4f7f\u7528\u8f03\u70ba\u50b3\u7d71\u65b9\u5f0f\u4f5c\u696d\u3002\u73fe\u5728\uff0c\u5982\u6b64\u5f37\u5927\u7684\u7ba1\u7406\u529f\u80fd\u5df2\u5b8c\u7f8e\u7d50\u5408\u81f3\u9032\u92b7\u5b58\u7cfb\u7d71\uff0c\u6211\u5011\u76f8\u4fe1\u5c0d\u65bc\u4e2d\u5c0f\u4f01\u696d\u4f86\u8aaa\u80fd\u5927\u5e45\u63d0\u5347\u5de5\u4f5c\u6548\u7387\u3002\u56e0\u6b64\u529f\u80fd\u4e0a\u7dda\u9996\u6ce2\u63a8\u51fa\u9650\u6642\u512a\u60e0\uff0c\u91dd\u5c0d\u820a\u6709\u5408\u7d04\u5ba2\u6236\u4e0d\u9650\u7248\u6b0a\u4eba\u6578\u512a\u60e0\u50f9\u53ea\u8981$10,500(\u542b\u7a05)\u3002<\/p>\n<p><!-- \/wp:paragraph --><\/p>\n<p><!-- wp:paragraph --><\/p>\n<p>\u6b61\u8fce\u4e0b\u8f09<a href=\"https:\/\/www.hserp.tw\/wordpress\/%e4%bc%81%e6%a5%ad%e6%b5%81%e7%a8%8b%e7%ae%a1%e7%90%86\/%e6%88%91%e7%ae%97%e7%ae%97-%e9%80%b2%e9%8a%b7%e5%ad%98\/\">\u6211\u7b97\u7b97\u9032\u92b7\u5b58\u8a66\u7528<\/a>\uff0c\u4ea6\u53ef\u4f86\u96fb\u6216\u900f\u904e\u7dda\u4e0a\u5ba2\u670d\u8aee\u8a62\uff0c\u8b93\u60a8\u6587\u4ef6\u6b78\u6a94\u597d\u67e5\u627e\uff01<\/p>\n<p><!-- \/wp:paragraph --><\/p>\n<p><!-- wp:paragraph --><\/p>\n<p><!-- \/wp:paragraph --><\/p>\n<p><!-- wp:buttons --><\/p>\n<div class=\"wp-block-buttons\"><!-- wp:button {\"backgroundColor\":\"vivid-red\",\"borderRadius\":0} -->\n<p>\u00a0<\/p>\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link has-background has-vivid-red-background-color no-border-radius\" href=\"https:\/\/www.hserp.tw\/wordpress\/%e4%bc%81%e6%a5%ad%e6%b5%81%e7%a8%8b%e7%ae%a1%e7%90%86\/%e6%88%91%e7%ae%97%e7%ae%97-%e9%80%b2%e9%8a%b7%e5%ad%98\/efile-o\/\/\" target=\"_blank\" rel=\"noreferrer noopener\"><strong>\u64cd\u4f5c\u4ecb\u7d39<\/strong><\/a><\/div>\n<p><!-- \/wp:button --><\/p>\n<\/div>\n<p><!-- \/wp:buttons --><\/p>","protected":false},"excerpt":{"rendered":"<p>\u653f\u5e9c\u63a8\u884c\u96fb\u5b50\u767c\u7968\u653f\u7b56\u6578\u9918\u5e74\uff0c\u76ee\u524d\u6b63\u671d\u5411\u5168\u9762\u7121\u7d19\u5316\u76ee\u6a19\u63a8\u52d5\u3002\u800c\u5947\u52dd\u8cc7\u8a0a\u540c\u6642\u4e5f\u63a8\u51fa\u6191\u8b49e\u5316\u9081\u5165\u7b2c\u4e94\u5e74\uff0c\u73fe\u5df2\u6709\u7d04\u56db\u6210\u6703\u8a08\u5e2b\u3001\u7a05 &hellip; <\/p>\n","protected":false},"author":1,"featured_media":1265,"comment_status":"open","ping_sta